# Copia este archivo a .env y llena los valores. .env está en .gitignore — NUNCA lo subas.

# Microsoft Clarity — Data Export API (scope Data.Export). Genera el JWT en el dashboard de Clarity.
CLARITY_TOKEN=

# Meta / Facebook — token con acceso al ad account GL-MEX2 (para fb-fetch.sh).
META_TOKEN=

# Supabase (proyecto ads-glmex2). En general se usa vía MCP connector, pero si corres SQL directo:
SUPABASE_URL=https://ksxmjrsscdhozkdgmpne.supabase.co
SUPABASE_SERVICE_KEY=

# n8n (base del usuario). Normalmente vía MCP connector.
N8N_BASE_URL=
N8N_API_KEY=
