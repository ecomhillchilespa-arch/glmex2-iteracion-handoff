    "image_with_text_FGDmzN": {
      "type": "image-with-text",
      "blocks": {
        "heading_zMHbWt": {
          "type": "heading",
          "settings": {
            "title": "POR QUÉ PETCLEAN™ ES LO MEJOR PARA TU PERRO Y TU GATO",
            "title_highlight_color": "#6d388b",
            "heading_size": "h1"
          }
        },
        "text_YNVi7b": {
          "type": "text",
          "settings": {
            "text": "<p>PetClean™ tiene el único ingrediente natural con estudios clínicos publicados: el <strong>Ascophyllum Nodosum</strong>. A diferencia de los snacks, actúa a <strong>nivel molecular</strong> dificultando que la placa se adhiera. Se <strong>rocía sobre la comida</strong> sin que tu mascota lo note gracias al <strong>sabor a res</strong> — funciona igual de bien en <strong>perros y gatos</strong>, incluso en los más mañosos. Avalado por evaluaciones veterinarias independientes. <strong>Sin cepillado, sin lucha, sin anestesia</strong>, con garantía de 30 días y una misión social. La elección más inteligente para cuidar su boca… y tu tranquilidad.</p>",
            "text_style": "body"
          }
        }
      },
      "block_order": [
        "heading_zMHbWt",
        "text_YNVi7b"
      ],
